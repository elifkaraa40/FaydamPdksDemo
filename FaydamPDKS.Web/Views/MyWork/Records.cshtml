@model FaydamPDKS.Web.Models.MyWorkViewModel
<details class="panel p-3 mb-4"><summary><strong>Geçmiş bir tarihte sahada olduğumu bildir</strong></summary><form class="admin-form mt-3" asp-action="CreateCorrection" method="post"><input type="hidden" name="CorrectionType" value="2"/><input type="hidden" name="RequestedEntry" value="08:30"/><input type="hidden" name="RequestedExit" value="18:00"/><div class="form-row"><div class="form-field"><label>Tarih</label><input name="WorkDate" type="date" min="@DateTime.Today.AddDays(-90).ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" required/></div><div class="form-field"><label>Proje</label><input name="ProjectName" maxlength="150"/></div></div><div class="form-row"><div class="form-field"><label>Müşteri</label><input name="CustomerName" maxlength="150"/></div><div class="form-field"><label>Saha adresi</label><input name="FieldAddress" maxlength="300"/></div></div><div class="form-field"><label>Gerekçe</label><textarea name="Reason" minlength="10" maxlength="500" required></textarea></div><button class="btn btn-primary" type="submit">Onaya gönder</button></form></details>
@{ ViewData["Title"] = "Çalışma Kayıtlarım"; static string Duration(int minutes) => $"{minutes / 60} sa {minutes % 60} dk"; static string Status(string value) => value switch { "Complete" => "Tamamlandı", "MissingEntry" => "Giriş eksik", "MissingExit" => "Çıkış eksik", "NoRecord" => "Kayıt yok", "NonWorkingDay" => "Çalışma dışı", _ => value }; }
@if(TempData["Success"] is string success){<div class="alert alert-success">@success</div>}@if(TempData["Error"] is string error){<div class="alert alert-danger">@error</div>}
<section class="dashboard-heading"><div><p class="eyebrow">Puantaj</p><h1>Çalışma Kayıtlarım</h1><p>Giriş-çıkış, çalışma süresi ve mola geçmişinizi inceleyin.</p></div><div class="hero-actions"><a class="btn btn-light" asp-action="ExportCsv" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")">CSV indir</a><a class="btn btn-success" asp-action="ExportExcel" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")">Excel indir</a><a class="btn btn-primary" asp-action="ExportPdf" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")">PDF indir</a></div></section>
<form method="get" class="panel p-3 mb-4"><div class="row g-3 align-items-end"><div class="col-md-4"><label class="form-label" for="from">Başlangıç</label><input class="form-control" id="from" name="from" type="date" value="@Model.From.ToString("yyyy-MM-dd")" /></div><div class="col-md-4"><label class="form-label" for="to">Bitiş</label><input class="form-control" id="to" name="to" type="date" value="@Model.To.ToString("yyyy-MM-dd")" /></div><div class="col-md-4"><button class="btn btn-outline-primary" type="submit">Görüntüle</button></div></div></form>
<section class="metric-grid"><div class="metric-card"><div><p>Çalışılan</p><strong>@Duration(Model.WorkedMinutes)</strong></div></div><div class="metric-card"><div><p>Beklenen</p><strong>@Duration(Model.ExpectedMinutes)</strong></div></div><div class="metric-card"><div><p>Fazla mesai</p><strong>@Duration(Model.OvertimeMinutes)</strong></div></div><div class="metric-card"><div><p>Eksik kayıt</p><strong>@Model.MissingRecordCount</strong></div></div></section>
<section class="panel mb-4"><div class="panel-heading"><div><p class="eyebrow">Dönem</p><h2>Giriş-çıkış kayıtları</h2></div></div><div class="table-responsive"><table class="table"><thead><tr><th>Tarih</th><th>Vardiya</th><th>Giriş</th><th>Çıkış</th><th>Çalışma</th><th>Fazla mesai</th><th>Durum</th></tr></thead><tbody>@foreach(var row in Model.Attendance){<tr><td>@row.WorkDate.ToString("dd.MM.yyyy")</td><td>@row.ShiftName</td><td>@(row.FirstEntry?.ToLocalTime().ToString("HH:mm") ?? "—")</td><td>@(row.LastExit?.ToLocalTime().ToString("HH:mm") ?? "—")</td><td>@Duration(row.WorkedMinutes)</td><td>@Duration(row.OvertimeMinutes)</td><td>@Status(row.Status)</td></tr>}</tbody></table></div></section>
<section class="panel"><div class="panel-heading"><div><p class="eyebrow">Molalar</p><h2>Mola geçmişim</h2></div></div><div class="table-responsive"><table class="table"><thead><tr><th>Başlangıç</th><th>Bitiş</th><th>Süre</th><th>Kapanış</th></tr></thead><tbody>@foreach(var item in Model.Breaks){<tr><td>@item.StartedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td><td>@(item.EndedAt?.ToLocalTime().ToString("HH:mm") ?? "Devam ediyor")</td><td>@(item.DurationMinutes.HasValue ? Duration(item.DurationMinutes.Value) : "—")</td><td>@(item.AutoClosed ? "Çıkışta otomatik" : "Normal")</td></tr>}</tbody></table></div></section>
<div class="content-grid mt-4"><section class="panel"><div class="panel-heading"><div><p class="eyebrow">Talepler</p><h2>Puantaj düzeltmelerim</h2></div></div><div class="table-responsive"><table class="table"><thead><tr><th>Tarih</th><th>Talep edilen</th><th>Gerekçe</th><th>Durum</th></tr></thead><tbody>@foreach(var item in Model.CorrectionRequests){<tr><td>@item.WorkDate.ToString("dd.MM.yyyy")</td><td>@item.RequestedEntry.ToString("HH:mm")–@item.RequestedExit.ToString("HH:mm")</td><td>@item.Reason<small>@item.ReviewNote</small></td><td>@(item.Status switch { FaydamPDKS.Core.Enums.AttendanceCorrectionStatus.Pending => "Bekliyor", FaydamPDKS.Core.Enums.AttendanceCorrectionStatus.Approved => "Onaylandı", FaydamPDKS.Core.Enums.AttendanceCorrectionStatus.Rejected => "Reddedildi", _ => item.Status.ToString() })</td></tr>}</tbody></table></div></section>
<aside class="panel create-panel"><div class="panel-heading"><div><p class="eyebrow">Eksik veya hatalı kayıt</p><h2>Düzeltme talep et</h2></div></div><form class="admin-form" asp-action="CreateCorrection" method="post"><div class="form-field"><label for="WorkDate">Çalışma tarihi</label><input id="WorkDate" name="WorkDate" type="date" min="@DateTime.Today.AddDays(-90).ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" required/></div><div class="form-row"><div class="form-field"><label for="RequestedEntry">Giriş saati</label><input id="RequestedEntry" name="RequestedEntry" type="time" required/></div><div class="form-field"><label for="RequestedExit">Çıkış saati</label><input id="RequestedExit" name="RequestedExit" type="time" required/></div></div><div class="form-field"><label for="Reason">Gerekçe</label><textarea id="Reason" name="Reason" minlength="10" maxlength="500" required></textarea><small>En az 10 karakter girin.</small></div><button class="btn btn-primary w-100" type="submit">Onaya gönder</button></form></aside></div>
