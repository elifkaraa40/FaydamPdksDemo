@model IReadOnlyList<FaydamPDKS.Core.DTOs.FieldWorkRequestDto>
@using FaydamPDKS.Core.Enums
@{ViewData["Title"]="Saha Görevlerim";}
<div class="page-header"><div><span class="eyebrow">ÇALIŞMA KONUMU</span><h1>Saha görevi talebi</h1><p>Gelecek tarihli saha çalışmalarınızı yönetici onayına gönderin.</p></div></div>
@if(TempData["Success"] is string ok){<div class="alert alert-success">@ok</div>} @if(TempData["Error"] is string err){<div class="alert alert-danger">@err</div>}
<section class="content-card mb-4"><form asp-action="CreateFieldWork" method="post" class="row g-3"><div class="col-md-3"><label class="form-label">Başlangıç</label><input type="date" name="StartDate" class="form-control" required/></div><div class="col-md-3"><label class="form-label">Bitiş</label><input type="date" name="EndDate" class="form-control" required/></div><div class="col-md-3"><label class="form-label">Tekrar</label><select name="RecurrenceType" class="form-select"><option value="1">Her iş günü</option><option value="2">Seçili günler</option></select></div><div class="col-md-3"><label class="form-label">Proje</label><input name="ProjectName" class="form-control" required/></div><div class="col-12 d-flex gap-3">@foreach(var d in new[]{(1,"Pzt"),(2,"Sal"),(3,"Çar"),(4,"Per"),(5,"Cum")}){<label><input type="checkbox" name="Days" value="@d.Item1"/> @d.Item2</label>}</div><div class="col-md-6"><input name="CustomerName" class="form-control" placeholder="Müşteri"/></div><div class="col-md-6"><input name="FieldAddress" class="form-control" placeholder="Saha adresi"/></div><div class="col-12"><textarea name="Reason" minlength="10" required class="form-control" placeholder="Görev gerekçesi"></textarea></div><div><button class="btn btn-primary">Talep gönder</button></div></form></section>
<section class="content-card"><h2>Taleplerim</h2><div class="table-responsive"><table class="table"><thead><tr><th>Tarih</th><th>Proje</th><th>Durum</th><th></th></tr></thead><tbody>@foreach(var x in Model){<tr><td>@x.StartDate.ToString("dd.MM.yyyy") – @x.EndDate.ToString("dd.MM.yyyy")</td><td>@x.ProjectName</td><td>@x.Status</td><td>@if(x.Status==WorkLocationRequestStatus.Pending){<form asp-action="CancelFieldWork" method="post"><input type="hidden" name="id" value="@x.Id"/><button class="btn btn-sm btn-outline-danger">İptal</button></form>}</td></tr>}</tbody></table></div></section>
