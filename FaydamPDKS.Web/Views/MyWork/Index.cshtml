@model FaydamPDKS.Web.Models.MyWorkViewModel
@{
    ViewData["Title"] = "Kontrol Paneli";
    static string Duration(int minutes) => $"{minutes / 60} sa {minutes % 60} dk";
    static string Status(string value) => value switch { "Complete" => "Tamamlandı", "MissingEntry" => "Giriş eksik", "MissingExit" => "Çıkış eksik", "NoRecord" => "Kayıt yok", "NonWorkingDay" => "Çalışma dışı", _ => value };
    var total = Math.Max(1, Model.Attendance.Count);
    var completeRate = Math.Round(Model.CompleteCount * 100d / total);
    var missingRate = Math.Round(Model.MissingRecordCount * 100d / total);
    var nonWorkingRate = Math.Round(Model.NonWorkingCount * 100d / total);
}
<section class="dashboard-heading"><div><p class="eyebrow">Personel portalı</p><h1>Kontrol Paneli</h1><p>Günlük çalışma durumunuz ve bu aya ait puantaj özetiniz.</p></div><a class="btn btn-primary" asp-action="Records">Çalışma kayıtlarımı aç</a></section>
<section class="metric-grid"><div class="metric-card"><div><p>Bugünkü durum</p><strong>@(Model.Today is null ? "Kayıt yok" : Status(Model.Today.Status))</strong><small>@DateTime.Today.ToString("dd.MM.yyyy")</small></div></div><div class="metric-card"><div><p>Bugün çalışılan</p><strong>@Duration(Model.Today?.WorkedMinutes ?? 0)</strong><small>Beklenen @Duration(Model.Today?.ExpectedMinutes ?? 510)</small></div></div><div class="metric-card"><div><p>Bu ay fazla mesai</p><strong>@Duration(Model.OvertimeMinutes)</strong><small>Hesaplanan toplam</small></div></div><div class="metric-card"><div><p>Bekleyen izin</p><strong>@Model.PendingLeaveCount</strong><small><a asp-action="Leaves">İzinlerimi aç</a></small></div></div></section>
<div class="dashboard-chart-grid"><section class="panel attendance-chart-panel"><div class="panel-heading"><div><p class="eyebrow">Bugünkü hareket</p><h2>Giriş ve çıkış</h2></div></div><div class="attendance-chart-body"><div><p>İlk giriş</p><h3>@(Model.Today?.FirstEntry?.ToLocalTime().ToString("HH:mm") ?? "—")</h3><p>Son çıkış</p><h3>@(Model.Today?.LastExit?.ToLocalTime().ToString("HH:mm") ?? "—")</h3></div><ul class="chart-legend personal-summary-list"><li><span>Çalışılan</span><strong>@Duration(Model.Today?.WorkedMinutes ?? 0)</strong></li><li><span>Fazla mesai</span><strong>@Duration(Model.Today?.OvertimeMinutes ?? 0)</strong></li><li><span>Durum</span><strong>@(Model.Today is null ? "Kayıt yok" : Status(Model.Today.Status))</strong></li></ul></div></section>
<section class="panel distribution-panel"><div class="panel-heading"><div><p class="eyebrow">Bu ay</p><h2>Puantaj dağılımı</h2></div></div><div class="bar-chart"><div><span><i style="height:@completeRate%"></i></span><strong>@Model.CompleteCount</strong><small>Tamamlanan</small></div><div><span><i class="bar-danger" style="height:@missingRate%"></i></span><strong>@Model.MissingRecordCount</strong><small>Eksik kayıt</small></div><div><span><i class="bar-info" style="height:@nonWorkingRate%"></i></span><strong>@Model.NonWorkingCount</strong><small>Çalışma dışı</small></div><div><span><i class="bar-warning" style="height:@Math.Min(100, Model.PendingLeaveCount * 25)%"></i></span><strong>@Model.PendingLeaveCount</strong><small>Bekleyen izin</small></div></div></section></div>
