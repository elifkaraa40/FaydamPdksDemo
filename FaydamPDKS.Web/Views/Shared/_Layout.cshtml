@inject FaydamPDKS.Core.Interfaces.INotificationRepository LayoutNotifications
@using System.Security.Claims
@using FaydamPDKS.Core.Enums
@{
    var uiTheme = Context.Request.Cookies["Faydam.Theme"] == "dark" ? "dark" : "light";
    var uiLanguage = Context.Request.Cookies["Faydam.Language"] == "en" ? "en" : "tr";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var isDashboard = currentController.Equals("Home", StringComparison.OrdinalIgnoreCase)
        && currentAction.Equals("Index", StringComparison.OrdinalIgnoreCase);
    var isPdks = new[] { "LeaveRequests", "AttendanceQr", "Shifts", "WorkCalendar", "Organization", "WorkLocations" }
        .Contains(currentController, StringComparer.OrdinalIgnoreCase)
        || (currentController.Equals("Modules", StringComparison.OrdinalIgnoreCase) && currentAction.Equals("Pdks", StringComparison.OrdinalIgnoreCase));
    var isPersonnel = new[] { "Employees", "Registrations" }.Contains(currentController, StringComparer.OrdinalIgnoreCase);
    var isReporting = new[] { "Reports", "Audit" }.Contains(currentController, StringComparer.OrdinalIgnoreCase)
        || (currentController.Equals("Modules", StringComparison.OrdinalIgnoreCase) && currentAction.Equals("Reporting", StringComparison.OrdinalIgnoreCase));
    var isActions = currentController.Equals("AttendanceCorrections", StringComparison.OrdinalIgnoreCase)
        || (currentController.Equals("Modules", StringComparison.OrdinalIgnoreCase) && currentAction.Equals("Operations", StringComparison.OrdinalIgnoreCase));
    var layoutNotificationItems = Array.Empty<FaydamPDKS.Core.Models.Notification>();
    if (User.Identity?.IsAuthenticated == true && Guid.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out var layoutUserId))
    {
        layoutNotificationItems = (await LayoutNotifications.GetForUserAsync(layoutUserId, 5)).Where(x => !x.IsRead).ToArray();
    }
    var unreadNotificationCount = layoutNotificationItems.Length;
}
<!DOCTYPE html>
<html lang="@uiLanguage" data-theme="@uiTheme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Faydam PDKS personel devam, vardiya ve izin yönetim sistemi." />
    <meta name="theme-color" content="#0f172a" />
    <title>@ViewData["Title"] | Faydam PDKS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FaydamPDKS.Web.styles.css" asp-append-version="true" />
</head>
<body data-theme="@uiTheme">
    <a class="skip-link" href="#main-content">Ana içeriğe geç</a>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg" aria-label="Ana menü">
            <div class="container-fluid px-lg-4">
                <a class="navbar-brand brand" asp-controller="Home" asp-action="Index" aria-label="Faydam PDKS ana sayfa">
                    <img class="navbar-logo" src="~/images/faydam-navbar-logo.png" alt="Faydam PDKS" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-between">
                    <ul class="navbar-nav ms-lg-4 gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link @((isDashboard || (currentController == "MyWork" && currentAction == "Index")) ? "active" : null)" asp-controller="@(User.IsInRole("Yonetici") ? "Home" : "MyWork")" asp-action="Index">@(uiLanguage == "en" ? "Dashboard" : "Kontrol Paneli")</a>
                        </li>
                        @if (User.IsInRole("Yonetici"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(isPdks ? "active" : null)" asp-controller="Modules" asp-action="Pdks" aria-current="@(isPdks ? "page" : null)">PDKS</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(isPersonnel ? "active" : null)" asp-controller="Employees" asp-action="Index" aria-current="@(isPersonnel ? "page" : null)">@(uiLanguage == "en" ? "Employees" : "Personel")</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(isReporting ? "active" : null)" asp-controller="Modules" asp-action="Reporting" aria-current="@(isReporting ? "page" : null)">@(uiLanguage == "en" ? "Reporting" : "Raporlama")</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(isActions ? "active" : null)" asp-controller="Modules" asp-action="Operations" aria-current="@(isActions ? "page" : null)">@(uiLanguage == "en" ? "Actions" : "İşlemler")</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link @(currentController == "MyWork" && currentAction == "FieldWork" ? "active" : null)" asp-controller="MyWork" asp-action="FieldWork">Çalışma Konumlarım</a></li>
                            <li class="nav-item"><a class="nav-link @(currentController == "MyWork" && currentAction == "Records" ? "active" : null)" asp-controller="MyWork" asp-action="Records">Çalışma Kayıtlarım</a></li>
                            <li class="nav-item"><a class="nav-link @(currentController == "MyWork" && currentAction == "Leaves" ? "active" : null)" asp-controller="MyWork" asp-action="Leaves">İzinlerim</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Account" asp-route-section="notifications">Bildirimlerim</a></li>
                        }
                    </ul>
                    <div class="user-menu navbar-tools">
                        <div class="global-search" data-global-search data-search-url="@Url.Action("Search", "Home")" data-search-scope="@(User.IsInRole("Yonetici") ? "manager" : "personal")">
                                <label class="navbar-search">
                                    <span class="visually-hidden">Genel arama</span>
                                    <input type="search" placeholder="@(User.IsInRole("Yonetici") ? "Personel veya sayfa ara" : "Sayfa ara")" aria-label="@(User.IsInRole("Yonetici") ? "Personel veya sayfa ara" : "Sayfa ara")" autocomplete="off" aria-expanded="false" aria-controls="global-search-results" />
                                    <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m21 21-4.2-4.2m1.2-5.3a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" /></svg>
                                </label>
                                <div class="global-search-results" id="global-search-results" role="listbox" hidden></div>
                        </div>
                        <a class="navbar-icon-link @(unreadNotificationCount > 0 ? "has-notifications" : null)" asp-controller="Home" asp-action="Account" asp-route-section="notifications" aria-label="@unreadNotificationCount okunmamış bildirim" title="Bildirimler">
                            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9Zm-8 12h4" /></svg>
                            @if (unreadNotificationCount > 0) { <span class="navbar-notification-badge">@unreadNotificationCount</span> }
                        </a>
                        <a class="navbar-icon-link" asp-controller="Home" asp-action="Help" aria-label="Yardım" title="Yardım">
                            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M9.8 9a2.4 2.4 0 1 1 3.7 2c-1 .6-1.5 1.1-1.5 2.5M12 17h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                        </a>
                        <a class="navbar-account" asp-controller="Home" asp-action="Account" aria-label="Hesabım">
                            @if (!string.IsNullOrWhiteSpace(User.FindFirst("profile_image")?.Value))
                            {
                                <img class="navbar-avatar image" src="@User.FindFirst("profile_image")!.Value" alt="" />
                            }
                            else
                            {
                                <span class="navbar-avatar">@((User.Identity?.Name ?? "F").Substring(0, 1).ToUpperInvariant())</span>
                            }
                            <span class="navbar-account-copy"><strong>@User.Identity?.Name</strong><small>@(uiLanguage == "en" ? "My account" : "Hesabım")</small></span>
                        </a>
                        <form asp-controller="Home" asp-action="Logout" method="post">
                            <button class="logout-button" type="submit">@(uiLanguage == "en" ? "Sign out" : "Çıkış")</button>
                        </form>
                    </div>
                </div>
            </div>
        </nav>
        @if (User.IsInRole("Yonetici") && (isPdks || isReporting || isActions))
        {
            <div class="context-nav-wrap">
                <nav class="context-nav container-fluid px-lg-4" aria-label="Modül alt menüsü">
                    @if (isPdks)
                    {
                        <a class="context-home @(currentController == "Modules" ? "active" : null)" asp-controller="Modules" asp-action="Pdks"><span>←</span> PDKS Merkezi</a>
                        <span class="context-divider" aria-hidden="true"></span>
                        <a class="@(currentController == "AttendanceQr" ? "active" : null)" asp-controller="AttendanceQr" asp-action="Index">Giriş-Çıkış</a>
                        <a class="@(currentController == "LeaveRequests" ? "active" : null)" asp-controller="LeaveRequests" asp-action="Index">İzin Yönetimi</a>
                        <a class="@(currentController == "Shifts" ? "active" : null)" asp-controller="Shifts" asp-action="Index">Vardiya ve Planlama</a>
                        <a class="@(currentController == "WorkCalendar" ? "active" : null)" asp-controller="WorkCalendar" asp-action="Index">Çalışma Takvimi</a>
                        <a class="@(currentController == "Organization" ? "active" : null)" asp-controller="Organization" asp-action="Index">Tanımlamalar</a>
                        <a class="@(currentController == "WorkLocations" ? "active" : null)" asp-controller="WorkLocations" asp-action="Index">Çalışma Konumları</a>
                    }
                    else if (isReporting)
                    {
                        <a class="context-home @(currentController == "Modules" ? "active" : null)" asp-controller="Modules" asp-action="Reporting"><span>←</span> Raporlama Merkezi</a>
                        <span class="context-divider" aria-hidden="true"></span>
                        <a class="@(currentController == "Reports" ? "active" : null)" asp-controller="Reports" asp-action="Index">PDKS Raporları</a>
                        <a class="@(currentController == "Audit" ? "active" : null)" asp-controller="Audit" asp-action="Index">Denetim Kayıtları</a>
                    }
                    else if (isActions)
                    {
                        <a class="context-home @(currentController == "Modules" ? "active" : null)" asp-controller="Modules" asp-action="Operations"><span>←</span> İşlemler Merkezi</a>
                        <span class="context-divider" aria-hidden="true"></span>
                        <a class="@(currentController == "AttendanceCorrections" ? "active" : null)" asp-controller="AttendanceCorrections" asp-action="Index">Puantaj Düzeltmeleri</a>
                        <a asp-controller="LeaveRequests" asp-action="Index">İzin Onayları</a>
                        <a asp-controller="AttendanceQr" asp-action="Index" asp-fragment="transitions">Geçiş Kayıtları</a>
                    }
                </nav>
            </div>
        }
    </header>
    @if (layoutNotificationItems.Length > 0)
    {
        <aside class="live-notifications" aria-label="Yeni bildirimler">
            <div class="container-fluid px-lg-4">
                <div class="live-notification-heading"><strong>Yeni bildirimleriniz var</strong><a asp-controller="Home" asp-action="Account" asp-route-section="notifications">Tümünü göster</a></div>
                @foreach (var item in layoutNotificationItems.Take(3))
                {
                    var isManagerNotice = User.IsInRole("Yonetici");
                    var targetController = isManagerNotice && item.Type == NotificationType.RegistrationApprovalRequested ? "Registrations" : isManagerNotice && item.Type == NotificationType.LeaveRequestCreated ? "LeaveRequests" : isManagerNotice && item.Type is NotificationType.AttendanceCorrectionCreated or NotificationType.MissingAttendanceDetected ? "AttendanceCorrections" : isManagerNotice && item.Type == NotificationType.FieldWorkRequestCreated ? "WorkLocations" : "MyWork";
                    var targetAction = !isManagerNotice && item.Type is NotificationType.LeaveApproved or NotificationType.LeaveRejected ? "Leaves" : !isManagerNotice && item.Type is NotificationType.AttendanceCorrectionApproved or NotificationType.AttendanceCorrectionRejected or NotificationType.AttendanceWarning ? "Records" : !isManagerNotice && item.Type is NotificationType.FieldWorkRequestApproved or NotificationType.FieldWorkRequestRejected or NotificationType.WorkLocationAssigned ? "FieldWork" : "Index";
                    <div class="live-notification-item">
                        <span aria-hidden="true"></span><div><strong>@item.Title</strong><p>@item.Message</p></div>
                        <form asp-controller="Home" asp-action="MarkNotificationRead" method="post"><input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="returnUrl" value="@Url.Action(targetAction, targetController)" /><button type="submit">Görüntüle ve kapat</button></form>
                    </div>
                }
            </div>
        </aside>
    }
    <div class="container-fluid app-shell px-lg-4">
        <main id="main-content" role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container-fluid px-lg-4">
            &copy; 2026 Faydam PDKS · Güvenli ve izlenebilir iş gücü yönetimi
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
