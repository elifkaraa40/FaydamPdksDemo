@model FaydamPDKS.Core.DTOs.WorkLocationPageDto
@using FaydamPDKS.Core.Enums
@{ ViewData["Title"] = "Çalışma Konumu Planları"; }
<div class="page-header"><div><span class="eyebrow">PDKS</span><h1>Çalışma Konumu Planları</h1><p>Uzaktan çalışma ve saha görevlerini haftanın günlerine göre planlayın.</p></div></div>
@if(TempData["Success"] is string ok){<div class="alert alert-success">@ok</div>} @if(TempData["Error"] is string err){<div class="alert alert-danger">@err</div>}
<section class="content-card mb-4"><h2>Yeni plan</h2><form asp-action="Create" method="post" class="row g-3" data-work-location-form>
<div class="col-md-4"><label class="form-label">Personel</label><select name="UserId" class="form-select" required><option value="">Seçin</option>@foreach(var e in Model.Employees){<option value="@e.Id">@e.FullName (@e.EmployeeNumber)</option>}</select></div>
<div class="col-md-2"><label class="form-label">Konum</label><select name="LocationType" class="form-select" data-work-location-type><option value="1">Uzaktan</option><option value="2">Saha görevi</option></select></div>
<div class="col-md-2"><label class="form-label">Başlangıç</label><input type="date" name="StartDate" class="form-control" required/></div><div class="col-md-2"><label class="form-label">Bitiş (boşsa süresiz)</label><input type="date" name="EndDate" class="form-control"/></div>
<div class="col-md-2"><label class="form-label">Tekrar</label><select name="RecurrenceType" class="form-select" data-recurrence-type><option value="3">Tekrarlanmaz</option><option value="1">Tarih aralığındaki her iş günü</option><option value="2">Seçili günler</option></select></div>
<div class="col-12" data-weekday-fields hidden><label class="form-label">Seçili günler</label><div class="d-flex flex-wrap gap-3">@foreach(var d in new[]{(1,"Pazartesi"),(2,"Salı"),(3,"Çarşamba"),(4,"Perşembe"),(5,"Cuma")}){<label><input type="checkbox" name="Days" value="@d.Item1"/> @d.Item2</label>}</div></div>
<div class="col-12 row g-3 m-0 p-0" data-field-work-fields hidden><div class="col-md-4"><label class="form-label">Proje</label><input name="ProjectName" class="form-control"/></div><div class="col-md-4"><label class="form-label">Müşteri</label><input name="CustomerName" class="form-control"/></div><div class="col-md-4"><label class="form-label">Saha adresi</label><input name="FieldAddress" class="form-control"/></div><div class="col-12"><label class="form-label">Görev açıklaması</label><textarea name="Reason" class="form-control"></textarea></div></div><div><button class="btn btn-primary">Planı kaydet</button></div></form></section>
<section class="content-card mb-4"><h2>Aktif planlar</h2><div class="table-responsive"><table class="table"><thead><tr><th>Personel</th><th>Konum</th><th>Tarih</th><th>Tekrar</th><th></th></tr></thead><tbody>@foreach(var x in Model.Assignments.Where(x=>x.IsActive)){<tr><td>@x.EmployeeName</td><td>@(x.LocationType==WorkLocationType.Field?"Saha görevi":"Uzaktan")</td><td>@x.StartDate.ToString("dd.MM.yyyy") – @(x.EndDate?.ToString("dd.MM.yyyy")??"Süresiz")</td><td>@(x.RecurrenceType switch { WorkLocationRecurrenceType.Once => "Tekrarlanmaz", WorkLocationRecurrenceType.EveryWorkday => "Tarih aralığındaki her iş günü", _ => string.Join(", ",x.Days) })</td><td><form asp-action="End" method="post"><input type="hidden" name="id" value="@x.Id"/><button class="btn btn-sm btn-outline-danger">Sonlandır</button></form></td></tr>}</tbody></table></div></section>
<section class="content-card"><h2>Bekleyen çalışma konumu talepleri</h2><div class="table-responsive"><table class="table"><thead><tr><th>Personel</th><th>Tür</th><th>Tarih</th><th>Detay</th><th></th></tr></thead><tbody>@foreach(var x in Model.Requests.Where(x=>x.Status==WorkLocationRequestStatus.Pending)){<tr><td>@x.EmployeeName</td><td>@(x.LocationType==WorkLocationType.Field?"Saha görevi":"Uzaktan çalışma")</td><td>@(x.StartDate==x.EndDate?x.StartDate.ToString("dd.MM.yyyy"):$"{x.StartDate:dd.MM.yyyy} – {x.EndDate:dd.MM.yyyy}")</td><td>@if(x.LocationType==WorkLocationType.Field){<strong>@x.ProjectName</strong><br/>}@x.Reason</td><td><form asp-action="Review" method="post" class="d-flex gap-2"><input type="hidden" name="id" value="@x.Id"/><button name="approve" value="true" class="btn btn-sm btn-success">Onayla</button><button name="approve" value="false" class="btn btn-sm btn-outline-danger">Reddet</button></form></td></tr>}</tbody></table></div></section>
