@model FaydamPDKS.Core.DTOs.AttendanceReportDto
@{
    ViewData["Title"] = "Puantaj Raporları";
    string StatusLabel(string status) => status switch { "Complete" => "Tamamlandı", "NoRecord" => "Kayıt yok", "NonWorkingDay" => "Çalışma dışı gün", "MissingEntry" => "Giriş eksik", "MissingExit" => "Çıkış eksik", "RemoteWork" => "Uzaktan çalışma", "FieldWork" => "Saha çalışması", _ => status };
    string WorkLocationLabel(string location) => location switch { "Remote" => "Uzaktan", "Field" => "Saha", _ => "Ofis" };
}
<section class="hero compact-hero">
    <div><p class="eyebrow">Raporlama</p><h1>Puantaj raporu</h1><p>Hesaplanan çalışma, geç kalma ve fazla mesai sonuçlarını inceleyin.</p></div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-light" asp-action="ExportCsv" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-employeeId="@Model.SelectedEmployeeId">CSV indir</a>
        <a class="btn btn-success" asp-action="ExportExcel" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-employeeId="@Model.SelectedEmployeeId">Excel indir</a>
        <a class="btn btn-primary" asp-action="ExportPdf" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-employeeId="@Model.SelectedEmployeeId">PDF indir</a>
    </div>
</section>

<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
<section class="panel report-filter" aria-labelledby="report-filter-title">
    <form asp-action="Index" method="get" class="filter-form">
        <h2 id="report-filter-title" class="visually-hidden">Rapor filtresi</h2>
        <div class="form-field"><label for="from">Başlangıç</label><input id="from" name="from" type="date" value="@Model.From.ToString("yyyy-MM-dd")" required /></div>
        <div class="form-field"><label for="to">Bitiş</label><input id="to" name="to" type="date" value="@Model.To.ToString("yyyy-MM-dd")" required /></div>
        <div class="form-field"><label for="employeeId">Personel</label><select id="employeeId" name="employeeId"><option value="">Tüm personel</option>@foreach (var employee in Model.Employees ?? []) { <option value="@employee.Id" selected="@(Model.SelectedEmployeeId == employee.Id ? "selected" : null)">@employee.EmployeeNumber · @employee.FullName</option> }</select></div>
        <button class="btn btn-primary" type="submit">Raporu getir</button>
        <small>Yöneticiler ve kayıtsız hafta sonları listeye alınmaz. En fazla 31 gün seçilebilir.</small>
    </form>
</section>

<section class="panel mt-4" aria-labelledby="report-list-title">
    <div class="panel-heading"><div><p class="eyebrow">@Model.From.ToString("dd.MM.yyyy") – @Model.To.ToString("dd.MM.yyyy")</p><h2 id="report-list-title">Günlük puantaj sonuçları</h2></div><span class="summary-pill">@Model.Rows.Count satır</span></div>
    @if (Model.Rows.Count == 0) { <div class="panel-empty"><strong>Seçilen aralıkta rapor satırı bulunamadı.</strong></div> }
    else { <div class="table-responsive"><table class="table align-middle">
        <thead><tr><th>Tarih</th><th>Personel</th><th>Vardiya</th><th>Çalışma şekli</th><th>Giriş / çıkış</th><th>Çalışma</th><th>Geç / fazla</th><th>Durum</th></tr></thead>
        <tbody>@foreach (var row in Model.Rows) { <tr>
            <td><strong>@row.WorkDate.ToString("dd.MM.yyyy")</strong></td>
            <td><strong>@row.EmployeeName</strong><small>@row.EmployeeNumber · @(row.Department ?? "Bölüm yok")</small></td>
            <td>@row.ShiftName</td>
            <td><strong>@WorkLocationLabel(row.WorkLocation)</strong><small>@row.WorkLocationDetail</small></td>
            <td>@(row.FirstEntry?.ToString("HH:mm") ?? "—") / @(row.LastExit?.ToString("HH:mm") ?? "—")</td>
            <td>@row.WorkedMinutes dk<small>Beklenen @row.ExpectedMinutes dk</small></td>
            <td>@row.LateMinutes dk<small>Fazla @row.OvertimeMinutes dk</small></td>
            <td><span class="status @(row.Status is "Complete" or "RemoteWork" or "FieldWork" ? "success" : row.Status is "NoRecord" or "NonWorkingDay" ? "neutral" : "warning")">@StatusLabel(row.Status)</span></td>
        </tr> }</tbody>
    </table></div> }
</section>
