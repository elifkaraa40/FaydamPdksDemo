@model FaydamPDKS.Core.DTOs.AttendanceReportDto
@{
    ViewData["Title"] = "Puantaj Raporları";
}
<section class="hero compact-hero">
    <div><p class="eyebrow">Raporlama</p><h1>Puantaj raporu</h1><p>Hesaplanan çalışma, geç kalma ve fazla mesai sonuçlarını inceleyin.</p></div>
    <a class="btn btn-primary" asp-action="ExportCsv" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")">CSV indir</a>
</section>

<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
<section class="panel report-filter" aria-labelledby="report-filter-title">
    <form asp-action="Index" method="get" class="filter-form">
        <h2 id="report-filter-title" class="visually-hidden">Rapor filtresi</h2>
        <div class="form-field"><label for="from">Başlangıç</label><input id="from" name="from" type="date" value="@Model.From.ToString("yyyy-MM-dd")" required /></div>
        <div class="form-field"><label for="to">Bitiş</label><input id="to" name="to" type="date" value="@Model.To.ToString("yyyy-MM-dd")" required /></div>
        <button class="btn btn-primary" type="submit">Raporu getir</button>
        <small>Performans ve okunabilirlik için en fazla 31 gün seçilebilir.</small>
    </form>
</section>

<section class="panel mt-4" aria-labelledby="report-list-title">
    <div class="panel-heading"><div><p class="eyebrow">@Model.From.ToString("dd.MM.yyyy") – @Model.To.ToString("dd.MM.yyyy")</p><h2 id="report-list-title">Günlük puantaj sonuçları</h2></div><span class="summary-pill">@Model.Rows.Count satır</span></div>
    @if (Model.Rows.Count == 0) { <div class="panel-empty"><strong>Seçilen aralıkta rapor satırı bulunamadı.</strong></div> }
    else { <div class="table-responsive"><table class="table align-middle">
        <thead><tr><th>Personel</th><th>Tarih / vardiya</th><th>Giriş / çıkış</th><th>Çalışma</th><th>Geç / fazla</th><th>Durum</th></tr></thead>
        <tbody>@foreach (var row in Model.Rows) { <tr>
            <td><strong>@row.EmployeeName</strong><small>@row.EmployeeNumber · @(row.Department ?? "Bölüm yok")</small></td>
            <td>@row.WorkDate.ToString("dd.MM.yyyy")<small>@row.ShiftName</small></td>
            <td>@(row.FirstEntry?.ToString("HH:mm") ?? "—") / @(row.LastExit?.ToString("HH:mm") ?? "—")</td>
            <td>@row.WorkedMinutes dk<small>Beklenen @row.ExpectedMinutes dk</small></td>
            <td>@row.LateMinutes dk<small>Fazla @row.OvertimeMinutes dk</small></td>
            <td><span class="status @(row.Status == "Complete" ? "success" : row.Status is "NoRecord" or "NonWorkingDay" ? "neutral" : "warning")">@(row.Status == "Complete" ? "Tamamlandı" : row.Status == "NoRecord" ? "Kayıt yok" : row.Status == "NonWorkingDay" ? "Çalışma dışı gün" : row.Status == "MissingEntry" ? "Giriş eksik" : "Çıkış eksik")</span></td>
        </tr> }</tbody>
    </table></div> }
</section>
