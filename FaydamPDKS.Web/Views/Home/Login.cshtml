@model FaydamPDKS.Web.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Giriş";
}
<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#173578" />
    <title>Giriş | Faydam PDKS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
    <main class="login-shell">
        <section class="login-brand" aria-labelledby="login-intro-title">
            <p class="login-product">Personel Devam Kontrol Sistemi</p>
            <div class="login-brand-content">
                <h1 id="login-intro-title">Güvenli ve hızlı erişim</h1>
                <p>Kurumsal kimlik bilgilerinizle sisteme giriş yaparak devam edebilirsiniz.</p>
            </div>
            <small>© 2026 Faydam İnovasyon</small>
        </section>
        <section class="login-card" aria-labelledby="login-title">
            <div class="login-card-inner">
                <img class="login-wordmark" src="~/images/faydam-login-wordmark.png" alt="Faydam" />
                <p class="eyebrow">Personel Devam Kontrol Sistemi</p>
                <h2 id="login-title">Sisteme giriş yapın</h2>
                <p class="login-subtitle">Hesabınıza erişmek için bilgilerinizi girin.</p>

                <form asp-action="Login" method="post" novalidate>
                    <input asp-for="ReturnUrl" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <div class="form-field">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" autocomplete="username" inputmode="email" autofocus />
                        <span asp-validation-for="Email"></span>
                    </div>
                    <div class="form-field">
                        <label asp-for="Password"></label>
                        <div class="password-field">
                            <input asp-for="Password" autocomplete="current-password" />
                            <button class="password-toggle" type="button" data-password-toggle aria-label="Parolayı göster" aria-pressed="false">
                                <svg class="eye-open" viewBox="0 0 24 24" aria-hidden="true"><path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z"/><circle cx="12" cy="12" r="2.7"/></svg>
                                <svg class="eye-closed" viewBox="0 0 24 24" aria-hidden="true"><path d="m3 3 18 18M10.6 6.1A10.8 10.8 0 0 1 12 6c6 0 9.5 6 9.5 6a17 17 0 0 1-2.1 2.8M6.5 6.6C3.9 8.3 2.5 12 2.5 12s3.5 6 9.5 6c1.2 0 2.3-.2 3.3-.6M9.9 9.9a3 3 0 0 0 4.2 4.2"/></svg>
                            </button>
                        </div>
                        <span asp-validation-for="Password"></span>
                    </div>
                    <label class="remember"><input asp-for="RememberMe" /> <span>Oturumu açık tut</span></label>
                    <button class="btn btn-primary login-button" type="submit">Giriş yap</button>
                </form>
                <p class="login-help">Hesabınıza erişemiyor musunuz? Sistem yöneticinizle iletişime geçin.</p>
            </div>
        </section>
    </main>
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
