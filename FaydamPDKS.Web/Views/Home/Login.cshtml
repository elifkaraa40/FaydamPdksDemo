@model FaydamPDKS.Web.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Giriş";
}
<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0f172a" />
    <title>Giriş | Faydam PDKS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
    <main class="login-shell">
        <section class="login-brand" aria-labelledby="login-intro-title">
            <a class="brand login-logo" asp-action="Login"><span>F</span> Faydam PDKS</a>
            <div>
                <p class="eyebrow">İş gücü yönetimi</p>
                <h1 id="login-intro-title">Ekibinizin zamanını<br />daha iyi yönetin.</h1>
                <p>Vardiya, izin ve devamlılık süreçleri tek, güvenli platformda.</p>
            </div>
            <small>© 2026 Faydam Teknoloji</small>
        </section>
        <section class="login-card" aria-labelledby="login-title">
            <div class="login-card-inner">
                <p class="eyebrow">Güvenli giriş</p>
                <h2 id="login-title">Tekrar hoş geldiniz</h2>
                <p class="login-subtitle">Devam etmek için kurumsal hesabınızla giriş yapın.</p>

                <form asp-action="Login" method="post" novalidate>
                    <input asp-for="ReturnUrl" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <div class="form-field">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" autocomplete="username" inputmode="email" autofocus />
                        <span asp-validation-for="Email"></span>
                    </div>
                    <div class="form-field">
                        <label asp-for="Password"></label>
                        <input asp-for="Password" autocomplete="current-password" />
                        <span asp-validation-for="Password"></span>
                    </div>
                    <label class="remember"><input asp-for="RememberMe" /> <span>Oturumu açık tut</span></label>
                    <button class="btn btn-primary login-button" type="submit">Giriş yap</button>
                </form>
                <p class="login-help">Hesabınıza erişemiyor musunuz? Sistem yöneticinizle iletişime geçin.</p>
            </div>
        </section>
    </main>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
